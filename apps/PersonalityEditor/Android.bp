android_app {
    name: "PersonalityEditor",
    srcs: ["src/**/*.java"],
    resource_dirs: ["res"],
    manifest: "AndroidManifest.xml",
    platform_apis: true,
    certificate: "platform",
    privileged: true,
    static_libs: [
        // za.co.circleos.personality.* AIDL stubs + Parcelables for
        // mode CRUD / community / managed-mode / learning-suggestions.
        "android.circleos-java",
    ],
    optimize: {
        enabled: false,
    },
}
